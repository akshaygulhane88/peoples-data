  "control": {
    "trm.practice_person_topic": {
      "name": "ETL_JOB_CONTROL",
      "type": "snowflake",
      "connection": {
        "sfdatabase": "$firmdb",
        "sfrole": "$firmrole"
      },
      "schema": "STG",
      "snowflake_source_name": "net.snowflake.spark.snowflake",
      "procname": "UPDATE_ETL_JOB_CONTROL_P",
      "dfquery": "select * from $firmdb.STG.ETL_JOB_CONTROL where job_name='INGEST_TRM_PRACTICE_PERSON_TOPIC_GLUE_FULL'",
      "procquery": "call $firmdb.STG.UPDATE_ETL_JOB_CONTROL_P('$firmdb','INGEST_TRM_PRACTICE_PERSON_TOPIC_GLUE_FULL',{0},{1})"
    }
  },
  "Source2Target": {
    "sources": {
      "ksr": {
        "trm.practice_person_topic": {
          "sourcedatabase": "postgres",
          "sourceschema": "TRM",
          "sourcetable": "TRM.PRACTICE_PERSON_TOPIC",
          "sourcequery": "select * from TRM.PRACTICE_PERSON_TOPIC",
          "load_type": "Full",
          "jdbcUrl": "$ksrtrmjdbcurl",
          "jdbcdriverpath": "s3://$gluebucket/Jar/postgresql.jar",
          "connectionProperties": {
            "secretname": "$ksrtrmsecret",
            "driver": "org.postgresql.Driver"
          }}}},
    "targets": {
      "s3": {
  
        "trm.practice_person_topic": {
          "target_bucket_name": "$peoplebucket",
          "target_key_name": "ksr/full/trm/practice_person_topic/",
          "target_partition_by": null,
          "target_write_mode": "overwrite",
          "target_file_format": "parquet",
          "writer_spark_options": {
            "target_compression_type": "snappy"
          }
        }
     }
    }
  }}