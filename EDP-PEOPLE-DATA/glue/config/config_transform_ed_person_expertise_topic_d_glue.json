
{
	"global": {
		"snowflake_source_name": "net.snowflake.spark.snowflake",
		"s3_client_name": "s3",
		"json_decode": "utf-8"
	},
	"environment": {
		"dev":{
		"snowflake_db_secret_name": "cdp-fdw-snowflake-dev",
		"database": "ENT_PEOPLE_DEV_DB",
		"role": "ENT_PEOPLE_OWNER_DEV_ROLE",
		"dynamic_vars":{"$peopledb":"ENT_PEOPLE_DEV_DB","$firmdb":"ENT_FIRM_DEV_DB","$firmrole":"ENT_FIRM_OWNER_DEV_ROLE","$peoplerole":"ENT_PEOPLE_OWNER_DEV_ROLE"}
		},
		"qa":{
		"snowflake_db_secret_name": "cdp-fdw-snowflake-qa",
		"database": "ENT_PEOPLE_QA_DB",
		"role": "ENT_PEOPLE_OWNER_QA_ROLE",
		"dynamic_vars":{"$peopledb":"ENT_PEOPLE_QA_DB","$firmdb":"ENT_FIRM_QA_DB","$firmrole":"ENT_FIRM_OWNER_QA_ROLE","$peoplerole":"ENT_PEOPLE_OWNER_QA_ROLE"}
		},
		"prod":{
		"snowflake_db_secret_name": "cdp-fdw-snowflake-prod",
		"database": "ENT_PEOPLE_PROD_DB",
		"role": "ENT_PEOPLE_OWNER_PROD_ROLE",
		"dynamic_vars":{"$peopledb":"ENT_PEOPLE_PROD_DB","$firmdb":"ENT_FIRM_PROD_DB","$firmrole":"ENT_FIRM_OWNER_PROD_ROLE","$peoplerole":"ENT_PEOPLE_OWNER_PROD_ROLE"}
		}
	},
	"job": {
		"name": "TRANSFORM_ED_PERSON_EXPERTISE_TOPIC_D_GLUE",
		"environment": "dev",
		"spark_options": [
			"set spark.sql.legacy.timeParserPolicy=LEGACY",
			"set spark.sql.ansi.enabled=True",
			"set spark.sql.storeAssignmentPolicy=ANSI"
		]
	},
	"control":{
		"name": "ETL_JOB_CONTROL",
		"type": "snowflake",
		"connection":{
		"sfdatabase": "$firmdb",
		"sfrole": "$firmrole"
		},
		"schema": "STG",
		"snowflake_source_name": "net.snowflake.spark.snowflake",
		"procname":"UPDATE_ETL_JOB_CONTROL_P",
		"dfquery": "select * from $firmdb.STG.ETL_JOB_CONTROL where job_name='TRANSFORM_ED_PERSON_EXPERTISE_TOPIC_D_GLUE'",
		"procquery": "call $firmdb.STG.UPDATE_ETL_JOB_CONTROL_P('$firmdb','TRANSFORM_ED_PERSON_EXPERTISE_TOPIC_D_GLUE',{0},{1})"
	},
	"stages": [
				{
			"stg_tables_stg_to_temp": {
				"sources": [
					{
						"name": "PERSON_EXPERTISE_TOPIC_STG",
						"type": "snowflake",
						"schema": "STG",
						"query": "SELECT FMNO, TOPIC_ID, TOPIC_NAME, TOPIC_DESCRIPTION, TOPIC_TAXONOMY_URL_ID, TAXONOMY_TAG_VALUE, TOPIC_TAXNOMY_TYPE, TOPIC_PRACTICE_URL_ID, PRACTICE_RECOMMENDED, FIRST_ALERT, START_DATE, END_DATE, CREATION_DATE, UPDATE_DATE, CHANGE_HASH FROM $peopledb.STG.PERSON_EXPERTISE_TOPIC_STG PET INNER JOIN $firmdb.STG.ETL_JOB_CONTROL EJC ON EJC.JOB_NAME = 'TRANSFORM_ED_PERSON_EXPERTISE_TOPIC_D_GLUE' WHERE PET.UPDATE_DATE >= DATEADD('DAY', -7, EJC.START_TIMESTAMP)",
						"spark_temp_vw_name": "PERSON_EXPERTISE_TOPIC_STG_DATA_TMP_V"
					}
				],
				"targets": [
					{
						"name": "PERSON_EXPERTISE_TOPIC_STG_TEMP",
						"type": "snowflake",
						"table": "PERSON_EXPERTISE_TOPIC_STG_TEMP",
						"write_mode": "overwrite",
						"schema": "TEMP"
					}
				]
			}
		},
		{
			"merge_temp_table_to_edw": {
				"sources": [
					{
						"name": "PERSON_EXPERTISE_TOPIC_STG_TEMP",
						"type": "snowflake",
						"schema": "TEMP",
						"table": "PERSON_EXPERTISE_TOPIC_STG_TEMP",
						"query": "",
						"write_mode": "overwrite"
					}
				],
				"targets": [
					{
						"name": "ED_PERSON_EXPERTISE_TOPIC_D",
						"type": "snowflake",
						"schema": "DATA"
					}
				]
			}
		}
	]
}